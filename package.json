{
  "name": "form-filling-agent-extension",
  "version": "1.0.0",
  "description": "Browser extension for AI-powered form filling agents",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "npm run build:extension && npm run build:next",
    "build:extension": "tsc --project tsconfig.extension.json",
    "build:next": "next build && next export",
    "start": "next start",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:diagnostic": "ts-node --project tsconfig.scripts.json scripts/diagnostic.ts",
    "test:benchmark": "ts-node --project tsconfig.scripts.json scripts/run-benchmark.ts",
    "test:quick": "ts-node --project tsconfig.scripts.json scripts/run-benchmark.ts --scenario quick",
    "test:full": "ts-node --project tsconfig.scripts.json scripts/run-benchmark.ts --scenario full",
    "test:domain": "ts-node --project tsconfig.scripts.json scripts/run-benchmark.ts --domain academic",
    "test:fallback": "node scripts/fallback-runner.js"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "next": "^14.0.0",
    "typescript": "^5.3.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.230",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.55.0",
    "eslint-config-next": "^14.0.0",
    "jest": "^29.5.0",
    "jest-environment-node": "^29.5.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.0"
  }
}
