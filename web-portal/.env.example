# Copy this file to .env.local and fill in real values

# OpenAI API key (optional — llm-structured agent falls back to rule-based without it)
OPENAI_API_KEY=sk-...

# Secret for session cookie signing (any long random string)
PORTAL_SESSION_SECRET=change-me-to-a-long-random-string

# FormFactory benchmark server (default: http://localhost:5000)
FORM_FACTORY_URL=http://localhost:5000
