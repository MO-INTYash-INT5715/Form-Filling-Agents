# GitHub Models endpoint (OpenAI-SDK compatible).
# Generate a fine-grained PAT with "Models: read" scope at
#   https://github.com/settings/tokens
# A Copilot-enabled account is enough; no extra subscription needed.
GITHUB_TOKEN=
LLM_BASE_URL=https://models.github.ai/inference
LLM_MODEL=openai/gpt-4o-mini
MAX_TURNS_PER_FORM=20

# Browser channel passed to @playwright/mcp.
# Use "chrome" to drive your installed Google Chrome (no chromium download).
# Other options: "msedge", "chrome-beta", "chromium".
MCP_BROWSER_CHANNEL=chrome
