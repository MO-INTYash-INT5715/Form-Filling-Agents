# GitHub Models endpoint (OpenAI-SDK compatible)
# ──────────────────────────────────────────────────────────────────────────────
# OPTION 1: GitHub Models (Copilot users with Models access)
#   1. Go to https://github.com/settings/tokens?type=beta
#   2. Generate token with "Models: read" permission
#   3. Set GITHUB_TOKEN below
#   4. Use LLM_BASE_URL=https://models.github.ai/inference
#
# OPTION 2: OpenAI Direct
#   1. Get API key from https://platform.openai.com/api-keys
#   2. Set OPENAI_API_KEY below
#   3. Use LLM_BASE_URL=https://api.openai.com/v1
#
# OPTION 3: Local LLM (Ollama / LM Studio)
#   1. Run: ollama serve (or start LM Studio server)
#   2. Set LLM_BASE_URL=http://localhost:11434/v1 (Ollama) or http://localhost:1234/v1 (LM Studio)
#   3. Set LLM_MODEL=llama3.2 (or your local model name)
#   4. Leave GITHUB_TOKEN and OPENAI_API_KEY blank
# ──────────────────────────────────────────────────────────────────────────────

# GitHub Models (requires Copilot + Models access)
GITHUB_TOKEN=
LLM_BASE_URL=https://models.github.ai/inference
LLM_MODEL=openai/gpt-4.1-mini

# OR: OpenAI Direct (uncomment and set OPENAI_API_KEY, comment out GITHUB_TOKEN)
# OPENAI_API_KEY=
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# OR: Local LLM (uncomment and configure)
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.2

# Agent configuration
MAX_TURNS_PER_FORM=20

# Browser selection for Playwright MCP
# Options: "chrome", "msedge", "chrome-beta", "chromium"
MCP_BROWSER_CHANNEL=chrome

# SSL workaround (corporate networks only - set to 0 if cert validation fails)
# WARNING: Only use in dev! Remove for production.
# NODE_TLS_REJECT_UNAUTHORIZED=0
