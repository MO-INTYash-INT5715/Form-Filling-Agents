{
  "name": "ffa-extension",
  "version": "1.0.0",
  "description": "Browser extension for AI-powered form filling agents",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "npm run build:extension && npm run build:next",
    "build:extension": "tsc --project tsconfig.extension.json",
    "build:next": "next build && next export",
    "start": "next start",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "benchmark:rule-based:quick": "tsx --tsconfig tsconfig.scripts.json scripts/run-benchmark.ts --quick --agent rule-based",
    "benchmark:rule-based:full": "tsx --tsconfig tsconfig.scripts.json scripts/run-benchmark.ts --full --agent rule-based",
    "benchmark:mcp-agent:quick": "tsx --tsconfig tsconfig.scripts.json scripts/run-benchmark.ts --quick --agent mcp-agent",
    "benchmark:mcp-agent:full": "tsx --tsconfig tsconfig.scripts.json scripts/run-benchmark.ts --full --agent mcp-agent",
    "benchmark:setup": "playwright install chromium",
    "benchmark:list": "tsx --tsconfig tsconfig.scripts.json scripts/run-benchmark.ts --list-forms",
    "benchmark:embedding": "tsx --tsconfig tsconfig.scripts.json scripts/run-benchmark.ts --quick --agent embedding-matcher",
    "benchmark:llm-structured:quick": "tsx --tsconfig tsconfig.scripts.json scripts/run-benchmark.ts --quick --agent llm-structured",
    "benchmark:hybrid:quick": "tsx --tsconfig tsconfig.scripts.json scripts/run-benchmark.ts --quick --agent hybrid",
    "benchmark:vlm-agent:quick": "tsx --tsconfig tsconfig.scripts.json scripts/run-benchmark.ts --quick --agent vlm-agent",
    "benchmark:vision-agent:quick": "tsx --tsconfig tsconfig.scripts.json scripts/run-benchmark.ts --quick --agent vision-agent",
    "ablation:quick": "tsx --tsconfig tsconfig.scripts.json scripts/ablation-study.ts --quick",
    "ablation:full": "tsx --tsconfig tsconfig.scripts.json scripts/ablation-study.ts",
    "ablation:agents": "tsx --tsconfig tsconfig.scripts.json scripts/ablation-study.ts --quick --agents",
    "benchmark:rule-based": "tsx --tsconfig tsconfig.scripts.json scripts/run-benchmark.ts --agent rule-based",
    "benchmark:llm-structured": "tsx --tsconfig tsconfig.scripts.json scripts/run-benchmark.ts --agent llm-structured",
    "benchmark:mcp-agent": "tsx --tsconfig tsconfig.scripts.json scripts/run-benchmark.ts --agent mcp-agent",
    "benchmark:vlm-agent": "tsx --tsconfig tsconfig.scripts.json scripts/run-benchmark.ts --agent vlm-agent",
    "benchmark:vision-agent": "tsx --tsconfig tsconfig.scripts.json scripts/run-benchmark.ts --agent vision-agent",
    "benchmark:hybrid": "tsx --tsconfig tsconfig.scripts.json scripts/run-benchmark.ts --agent hybrid",
    "ablation": "tsx --tsconfig tsconfig.scripts.json scripts/ablation-study.ts"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "next": "^14.0.0",
    "openai": "^6.39.0",
    "playwright": "^1.44.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.230",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.55.0",
    "eslint-config-next": "^14.0.0",
    "jest": "^29.5.0",
    "jest-environment-node": "^29.5.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3"
  }
}