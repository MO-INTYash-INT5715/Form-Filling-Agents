# LLM Configuration
# Set the provider: 'openai', 'ollama', or 'custom'
LLM_PROVIDER=ollama

# For OpenAI or OpenAI-compatible cloud services (e.g., DeepSeek, Together, Anthropic via wrapper)
OPENAI_API_KEY=your_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1

# For Local LLMs (Ollama)
OLLAMA_BASE_URL=http://localhost:11434/v1

# Model selection
# For OpenAI: gpt-4o, gpt-4o-mini
# For Ollama: gemma3:12b, llama3, mistral, phi3
LLM_MODEL=gemma3:12b
