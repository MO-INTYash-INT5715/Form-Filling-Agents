# ============================================================
# FFA — LLM Provider Configuration  (copy to .env and fill in)
# ============================================================

# Active provider: openai | ollama | gemini | cerebras | bedrock
# Use 'openai' for OpenAI/gateways; use 'bedrock' for native AWS Bedrock Converse API.
LLM_PROVIDER=openai

# --- AWS Bedrock Native API (use with LLM_PROVIDER=bedrock) --
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=


# --- OpenAI / OpenAI-compatible gateway ----------------------
OPENAI_API_KEY=your_key_here
# For AWS Bedrock Mantle gateway:
#   OPENAI_BASE_URL=https://bedrock-mantle.<region>.api.aws/v1
#   OPENAI_API_KEY=<AWS_BEARER_TOKEN_BEDROCK>
# For standard OpenAI:
#   OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# Chat/LLM model
# OpenAI:       gpt-4o-mini
# Bedrock:      amazon.nova-lite-v1:0  |  amazon.nova-pro-v1:0
# Ollama:       gemma3:12b  |  mistral:13b
# Cerebras:     gpt-oss-120b
LLM_MODEL=gpt-4o-mini

# --- Cerebras ------------------------------------------------
# Fast OpenAI-compatible inference; 5 req/min on free tier
# CEREBRAS_API_KEY=csk-your-key-here

# Embeddings model (used by embedding-matcher agent)
# OpenAI:       text-embedding-3-small
# Bedrock:      amazon.titan-embed-text-v2:0
# Ollama:       (falls back to local deterministic embedder)
EMBEDDING_MODEL=text-embedding-3-small

# --- Gemini --------------------------------------------------
GEMINI_API_KEY=your_gemini_key_here

# --- Ollama (local) ------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434/v1

# --- FormFactory server --------------------------------------
FORMFACTORY_DATA=C:\Code\formfactory
FORMFACTORY_SERVER=http://localhost:5000

# --- Corporate SSL (if behind SSL-inspecting proxy) ----------
# Export the proxy's root CA cert and set this path:
# NODE_EXTRA_CA_CERTS=C:\certs\corp-root-ca.pem
