{
  "manifest_version": 2,
  "name": "Form Filling Agent",
  "version": "1.0.0",
  "description": "AI-powered form filling agent for commercial forms and document uploads",
  "permissions": [
    "storage",
    "<all_urls>"
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Form Filling Agent"
  },
  "background": {
    "scripts": ["js/background/service-worker.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["js/content/content-script.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "options_page": "options.html",
  "icons": {
    "16": "images/icon-16.svg",
    "48": "images/icon-48.svg",
    "128": "images/icon-128.svg"
  },
}
